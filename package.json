{
  "name": "nostr-dm-bot",
  "version": "8.0.0",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "watch": "bun run scripts/run-with-restart.ts",
    "lint": "eslint . --fix",
    "wallet:setup": "bun run scripts/setup-wallet.ts",
    "nostr:setup": "bun run scripts/nostr-setup.ts",
    "bot:setup": "bun run scripts/bot-setup.ts",
    "contrib:setup": "chmod +x scripts/commit-msg scripts/post-commit scripts/ngit-helper.sh && git config include.path ../.gitconfig",
    "plugin:publish": "bun run scripts/publish-plugin.ts",
    "plugin:install": "bun run scripts/install-plugin.ts",
    "plugin:new": "bun run scripts/new-plugin.ts",
    "plugin:generate": "bun run scripts/generate-tools.ts",
    "release:changelog": "bun run scripts/release-changelog.ts"
  },
  "dependencies": {
    "@cashu/cashu-ts": "^3.5.0",
    "@noble/ciphers": "^2.1.1",
    "@noble/hashes": "^2.0.1",
    "@opencode-ai/sdk": "^1.2.16",
    "@scure/bip39": "^2.0.1",
    "croner": "^8.0.0",
    "nostr-tools": "^2.23.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/bun": "^1.3.10",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.0"
  }
}
