{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "paths": {
      "@src/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "scripts/*.ts", "plugins/**/*", "generated/**/*"],
  "exclude": ["scripts/plugin-template/**/*"]
}
