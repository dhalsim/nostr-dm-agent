# Copy to .env and fill in your values.
# See README.md for full configuration and kind 10050 setup.

# Bot's private key (hex, 64 chars)
BOT_KEY=your_bot_private_key_hex

# Your (master) public key (hex) – only you can command the bot
BOT_MASTER_PUBKEY=your_master_public_key_hex

# Comma-separated relay URLs where the bot listens and receives DMs. First URL must match the relay in the bot's kind 10050.
BOT_RELAYS=wss://auth.nostr1.com/,wss://relay.damus.io

# Optional: set to 1 for debug logging
# DEBUG=1

# Optional: set to 0 to disable local terminal chat (e.g. when running as a daemon)
# BOT_LOCAL_CLI=0

# Optional: override PATH for locating agent binaries (cursor 'agent', 'opencode')
# BOT_AGENT_PATH=/usr/local/bin:/opt/homebrew/bin

# --- Cursor backend (switch via !backend cursor) ---

# Cursor API key
# CURSOR_API_KEY=your_cursor_api_key

# --- OpenCode backend (switch via !backend opencode) ---

# Optional: attach all opencode run calls to a persistent server (avoids MCP cold boot per message)
# Start the server with: opencode serve --port 4096
# BOT_OPENCODE_SERVE_URL=http://localhost:4096

# Optional: enable experimental plan mode in opencode (behaviour undocumented)
# OPENCODE_EXPERIMENTAL_PLAN_MODE=true

# --- OpenCode SDK backend (switch via !backend opencode-sdk) ---

# Optional: port for the in-process OpenCode server (default: try 4096, 4097, 4098, 4099)
# Set if 4096 is in use (e.g. by another "opencode serve")
# OPENCODE_SDK_PORT=4097

# --- Cashu / Routstr (optional: paid AI via Cashu) ---

# CASHU_DEFAULT_MINT_URL=https://mint.minibits.cash/Bitcoin

# Cashu wallet mnemonic (12 words). Generate with: npm run wallet:setup
# CASHU_MNEMONIC="..."

